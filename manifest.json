{
  "manifest_version": 3,
  "name": "Table Cruncher (Side Panel)",
  "version": "1.4",
  "permissions": [
    "storage",
    "sidePanel",
    "contextMenus",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "계산기 열기"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}